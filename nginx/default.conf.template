server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # Vite SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Forward Anthropic requests from the browser via Nginx
    location /api/anthropic/ {
        proxy_pass https://api.anthropic.com/;
        proxy_http_version 1.1;

        proxy_set_header Host api.anthropic.com;
        proxy_set_header x-api-key "${VITE_ANTHROPIC_API_KEY}";
        proxy_set_header anthropic-version "2023-06-01";
        proxy_set_header anthropic-dangerous-direct-browser-access "true";
        proxy_set_header content-type "application/json";
    }
}
